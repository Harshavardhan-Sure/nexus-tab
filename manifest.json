{
  "manifest_version": 3,
  "name": "Nexus Tab",
  "version": "1.0.0",
  "description": "A premium, distraction-free search dashboard for your new tab.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Nexus Tab",
    "default_popup": "popup.html"
  },
  "permissions": [
    "contextMenus",
    "bookmarks",
    "history",
    "topSites"
  ],
  "host_permissions": [
    "https://suggestqueries.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
